# ==============================================
# 1. 系统通用缓存（全平台生效）
# ==============================================
.DS_Store
Thumbs.db
*.tmp
*.temp

# ==============================================
# 2. 编辑器/IDE 个人配置（全项目生效）
# ==============================================
# PyCharm (覆盖所有子项目的 .idea)
**/.idea/
*.iws
*.iml
*.ipr

# VSCode
**/.vscode/
*.swp
*.swo

# ==============================================
# 3. Python 项目通用（覆盖 模型 + HUT后端）
# ==============================================
# 虚拟环境（自动屏蔽所有子文件夹下的 venv）
**/venv/
**/.venv/
**/env/
**/ENV/

# Python 字节码缓存
**/__pycache__/
*.py[cod]
*$py.class

# Python 测试缓存
**/.pytest_cache/

# Python 打包构建产物
**/build/
**/dist/
*.egg-info/

# ==============================================
# 4. 前端 Vue 项目通用（覆盖 前端文件夹）
# ==============================================
# 依赖包（自动屏蔽前端/node_modules）
**/node_modules/

# 打包构建产物
**/dist/
**/dist-ssr/
*.local

# npm 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================================
# 5. 敏感配置与本地数据
# ==============================================
# 环境变量（保留 .env.example 示例模板）
.env
.env.local
.env.*.local

# 本地数据库文件
*.db
*.sqlite
*.sqlite3

# ==============================================
# 6. AI 模型大权重文件（核心！防止上传失败）
# ==============================================
# 自动屏蔽所有子文件夹下的模型大文件（包括 model、model_param 等）
*.pth
*.pt
*.pkl
*.bin
*.ckpt
*.onnx
*.pb

# ==============================================
# 7. 运行日志与临时文件
# ==============================================
*.log
**/logs/
nohup.out